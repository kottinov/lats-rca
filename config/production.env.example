# Production Environment Configuration
# Deploy this configuration to production environment

# OpenAI Configuration
OPENAI_API_KEY=sk-production-api-key-from-secrets-manager
OPENAI_MODEL=gpt-4o  # Use best model for production

# Tavily Configuration
TAVILY_API_KEY=tvly-production-api-key-from-secrets-manager

# LATS Configuration (full parameters)
LATS_N_CANDIDATES=5
LATS_MAX_DEPTH=5
LATS_EXPLORATION_WEIGHT=1.41

# Logging (structured JSON for log aggregation)
LOG_LEVEL=INFO
LOG_FORMAT=json
