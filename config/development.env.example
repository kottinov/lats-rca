# Development Environment Configuration
# Copy to .env in project root for development

# OpenAI Configuration
OPENAI_API_KEY=sk-your-development-api-key
OPENAI_MODEL=gpt-4o-mini  # Use cheaper model for development

# Tavily Configuration
TAVILY_API_KEY=tvly-your-development-api-key

# LATS Configuration (smaller values for faster iteration)
LATS_N_CANDIDATES=3
LATS_MAX_DEPTH=3
LATS_EXPLORATION_WEIGHT=1.41

# Logging (more verbose for debugging)
LOG_LEVEL=DEBUG
LOG_FORMAT=text
